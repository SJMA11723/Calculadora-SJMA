<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="com.sjma11723.calculadorasjma.MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#999999"
        android:id="@+id/scrollView">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|top"
            android:text="Felíz Navidad ;)"
            android:textSize="110sp"
            android:textStyle="bold"
            tools:ignore="RtlHardcoded" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="168dp"
        android:orientation="horizontal">
        <Button
            android:id="@+id/buttonRaiz"
            android:layout_width="320dp"
            android:textSize="80sp"
            android:layout_height="match_parent"
            android:textStyle="bold"
            android:text="√"/>
        <Button
            android:id="@+id/buttonPotencia"
            android:layout_width="160dp"
            android:textSize="80sp"
            android:layout_height="match_parent"
            android:textStyle="bold"
            android:text="^"/>
        <Button
            android:id="@+id/buttonClear"
            android:layout_width="160dp"
            android:textSize="80sp"
            android:layout_height="match_parent"
            android:text="C"/>

        <ImageButton
            android:id="@+id/buttonBorrar"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_input_delete"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="168dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button7"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="7" />

        <Button
            android:id="@+id/button8"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="8" />

        <Button
            android:id="@+id/button9"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="9" />

        <Button
            android:id="@+id/buttonParentesis"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="{()}" />

        <Button
            android:id="@+id/buttonMenorQue"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="168dp"
        android:orientation="horizontal">
        <Button
            android:id="@+id/button4"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="4"/>
        <Button
            android:id="@+id/button5"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="5"/>
        <Button
            android:id="@+id/button6"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="6"/>
        <Button
            android:id="@+id/buttonDiv"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="/"/>
        <Button
            android:id="@+id/buttonMayorQue"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="168dp"
        android:orientation="horizontal">
        <Button
            android:id="@+id/button1"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="1"/>
        <Button
            android:id="@+id/button2"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="2"/>
        <Button
            android:id="@+id/button3"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="3"/>
        <Button
            android:id="@+id/buttonSuma"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="+"/>
        <Button
            android:id="@+id/buttonResta"
            android:textStyle="bold"
            android:textSize="80sp"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="-"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="168dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonPunto"
            android:layout_width="160dp"
            android:textSize="80sp"
            android:layout_height="match_parent"
            android:text="."
            android:textStyle="bold" />

        <Button
            android:id="@+id/button0"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="0"
            android:textSize="80sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonERROR"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="ERROR"
            android:textStyle="bold"
            android:textSize="40sp"/>

        <Button
            android:id="@+id/buttonMulti"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="X"
            android:textStyle="bold"
            android:textSize="80sp"/>

        <Button
            android:id="@+id/buttonIgual"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:text="="
            android:textStyle="bold"
            android:textSize="80sp"/>
    </LinearLayout>

</LinearLayout>