<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorPrimary"
    tools:context="com.sjma11723.calculadorasjma.MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:background="#999999"
        android:id="@+id/scrollView">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|center_vertical"
            android:text="@string/bienvenida"
            android:textSize="30sp"
            android:textStyle="bold"
            tools:ignore="RtlHardcoded" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">
        <Button
            android:id="@+id/buttonRaiz"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:textStyle="bold"
            android:text="√"/>

        <Button
            android:id="@+id/buttonParentesisApertura"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="(" />

        <Button
            android:id="@+id/buttonParentesisCierre"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text=")" />

        <Button
            android:id="@+id/buttonClear"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="C"/>

        <ImageButton
            android:id="@+id/buttonBorrar"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_input_delete"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button7"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="7" />

        <Button
            android:id="@+id/button8"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="8" />

        <Button
            android:id="@+id/button9"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="9" />

        <Button
            android:id="@+id/buttonPotencia"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:textStyle="bold"
            android:text="^"/>

        <Button
            android:id="@+id/buttonMenorQue"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">
        <Button
            android:id="@+id/button4"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="4"/>
        <Button
            android:id="@+id/button5"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="5"/>
        <Button
            android:id="@+id/button6"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="6"/>
        <Button
            android:id="@+id/buttonDiv"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="/"/>
        <Button
            android:id="@+id/buttonMayorQue"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">
        <Button
            android:id="@+id/button1"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="1"/>
        <Button
            android:id="@+id/button2"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="2"/>
        <Button
            android:id="@+id/button3"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="3"/>
        <Button
            android:id="@+id/buttonSuma"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="+"/>
        <Button
            android:id="@+id/buttonResta"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="-"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonPunto"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="." />

        <Button
            android:id="@+id/button0"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="0" />

        <Button
            android:id="@+id/buttonERROR"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="ERROR" />

        <Button
            android:id="@+id/buttonMulti"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="x" />

        <Button
            android:id="@+id/buttonIgual"
            android:textStyle="bold"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:text="=" />
    </LinearLayout>

</LinearLayout>